+// Phase 2a Task 4: minimal zbus proxy to supergfxd for GPU-mode auto-switch.
+//
+// asusd runs on the system bus. supergfxd runs on the system bus. Both use
+// the same Connection::system() root — no cross-bus routing.
+//
+// SetMode signature (introspected on our fork's supergfxd 5.2.7):
+//   Service:   org.supergfxctl.Daemon
+//   Path:      /org/supergfxctl/Gfx
+//   Interface: org.supergfxctl.Daemon
+//   Method:    SetMode(in u mode, out u user_action)
+//
+// The `mode` argument is the u32 discriminant of supergfxctl::GfxMode. We
+// avoid pulling supergfxctl in as a build dep by hardcoding only the two
+// values we ever auto-switch to (Hybrid=0, Integrated=1). AsusMuxDgpu is
+// structurally excluded — see AutoGfxMode below.
+
+use log::{debug, warn};
+use serde::{Deserialize, Serialize};
+use zbus::proxy;
+
+/// Modes safe for automatic switching on AC/battery. Deliberately does NOT
+/// include AsusMuxDgpu — that's reboot-required, hostile UX for anything
+/// automatic.
+#[derive(Debug, Default, Clone, Copy, PartialEq, Eq, Deserialize, Serialize)]
+pub enum AutoGfxMode {
+    #[default]
+    Hybrid,
+    Integrated,
+}
+
+impl AutoGfxMode {
+    /// The u32 the supergfxctl::GfxMode enum uses on the wire.
+    /// Hybrid=0, Integrated=1 — see supergfxctl/src/pci_device.rs GfxMode.
+    pub const fn as_u32(self) -> u32 {
+        match self {
+            Self::Hybrid => 0,
+            Self::Integrated => 1,
+        }
+    }
+}
+
+#[proxy(
+    interface = "org.supergfxctl.Daemon",
+    default_service = "org.supergfxctl.Daemon",
+    default_path = "/org/supergfxctl/Gfx"
+)]
+trait SupergfxDbus {
+    async fn set_mode(&self, mode: u32) -> zbus::Result<u32>;
+}
+
+pub struct SupergfxdClient {
+    proxy: SupergfxDbusProxy<'static>,
+}
+
+impl SupergfxdClient {
+    /// Connect on the system bus. Errors if supergfxd isn't running or
+    /// its bus name isn't claimed.
+    pub async fn new() -> Result<Self, zbus::Error> {
+        let conn = zbus::Connection::system().await?;
+        let proxy = SupergfxDbusProxy::new(&conn).await?;
+        Ok(Self { proxy })
+    }
+
+    /// Queue a mode change. supergfxd handles staging (logout-required).
+    /// Returns the `UserActionRequired` u32 value supergfxd reports back
+    /// for logging.
+    pub async fn set_mode(&self, mode: AutoGfxMode) -> Result<u32, zbus::Error> {
+        debug!("supergfxd_client: SetMode({mode:?})");
+        let reply = self.proxy.set_mode(mode.as_u32()).await?;
+        debug!("supergfxd_client: SetMode reply user_action_required={reply}");
+        Ok(reply)
+    }
+}
+
+impl std::fmt::Debug for SupergfxdClient {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        f.debug_struct("SupergfxdClient").finish()
+    }
+}
+
+// Emit a warning if the module is used from a code path where supergfxd
+// isn't reachable — surfaces the miswiring at runtime rather than silently
+// no-oping.
+pub fn warn_no_supergfxd() {
+    warn!(
+        "supergfxd_client: supergfxd is not reachable on the system dbus; \
+         GPU-mode auto-switch cannot fire. Install supergfxd or turn off \
+         change_gpu_mode_on_power in asusd.ron."
+    );
+}
