#!/usr/bin/make -f
export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo-home
export PATH := $(HOME)/.cargo/bin:$(PATH)

%:
	dh $@

override_dh_auto_configure:
	# Noble's apt rustc (1.75) is too old for relm4/zbus deps (need ≥1.92).
	# Install a compatible toolchain via rustup if the system one is too old.
	if ! rustc --version 2>/dev/null | awk '{split($$2,v,"."); exit !(v[1]>1 || (v[1]==1 && v[2]>=92))}'; then \
	    curl -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.92.0 --no-modify-path --profile minimal; \
	fi

override_dh_auto_build:
	PATH="$(HOME)/.cargo/bin:$(PATH)" cargo build --release --offline --ignore-rust-version

override_dh_auto_install:
	install -Dm755 target/release/utu \
		$(DESTDIR)/usr/bin/utu
	install -Dm644 debian/utu.desktop \
		$(DESTDIR)/usr/share/applications/io.github.baraka_malila.utu.desktop
	install -Dm644 assets/trayicon.png \
		$(DESTDIR)/usr/share/icons/hicolor/128x128/apps/io.github.baraka_malila.utu.png
	cp -r assets/anime $(DESTDIR)/usr/share/utu/anime

override_dh_auto_test:
	# no automated tests
