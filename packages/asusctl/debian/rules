#!/usr/bin/make -f
export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo-home
export PATH := $(HOME)/.cargo/bin:$(PATH)

# Skip binaries we don't ship in v0.1: asusd-user (session daemon) and
# rog-control-center (Slint GUI, rejected by design).

%:
	dh $@ --with quilt

override_dh_auto_clean:
	# Upstream Makefile distclean removes vendor/ and .cargo/ which we ship
	# in the orig tarball for offline Launchpad builds — skip it.

override_dh_auto_build:
	# vendor/toml 1.1.2 uses edition="2024" which cargo 1.75 (Ubuntu's apt version) cannot
	# parse. toml is only a dependency of excluded rog-control-center, so changing the edition
	# field to "2021" is safe — it never gets compiled. Checksum must be updated to match.
	python3 -c "import json,os,hashlib;t='vendor/toml/Cargo.toml';cp='vendor/toml/.cargo-checksum.json';[(open(t,'wb').write(p),json.dump(dict(cs,files=dict(cs['files'],**{'Cargo.toml':hashlib.sha256(p).hexdigest()})),open(cp,'w'),separators=(',',':')))for r in[open(t,'rb').read()if os.path.exists(t)else b'']for p in[r.replace(b'edition = \"2024\"',b'edition = \"2021\"')]if r and r!=p and os.path.exists(cp)for cs in[json.load(open(cp))]]"
	cargo build --release --workspace \
	    --offline \
	    --ignore-rust-version \
	    --exclude asusd-user \
	    --exclude rog-control-center \
	    --exclude rog_simulators

override_dh_auto_test:
	# Upstream cargo tests reach hardware; skip in the pbuilder chroot.

override_dh_auto_install:
	# Handled via debian/asusctl.install (enumerated).
