#!/usr/bin/make -f
export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo-home
export PATH := $(HOME)/.cargo/bin:$(PATH)

# Skip binaries we don't ship in v0.1: asusd-user (session daemon) and
# rog-control-center (Slint GUI, rejected by design).

%:
	dh $@ --with quilt

override_dh_auto_clean:
	# Upstream Makefile distclean removes vendor/ and .cargo/ which we ship
	# in the orig tarball for offline Launchpad builds — skip it.

override_dh_auto_build:
	# Strip stale .orig checksum entries left by quilt clean before building.
	python3 -c 'import json,os;[json.dump(dict(d,files={k:v for k,v in d["files"].items() if not k.endswith(".orig")}),open(p,"w"),separators=(",",":")) for c in(os.listdir("vendor")if os.path.isdir("vendor")else[])for p in[os.path.join("vendor",c,".cargo-checksum.json")]if os.path.exists(p)for d in[json.load(open(p))]]'
	# Patch every vendor crate that declares edition="2024" → "2021" and update
	# its cargo checksum. cargo 1.75 cannot parse edition 2024 manifests.
	python3 -c 'import json,os,hashlib;[(open(t,"wb").write(p),json.dump(dict(cs,files=dict(cs["files"],**{"Cargo.toml":hashlib.sha256(p).hexdigest()})),open(cp,"w"),separators=(",",":")))for c in(os.listdir("vendor")if os.path.isdir("vendor")else[])for t in[os.path.join("vendor",c,"Cargo.toml")]for cp in[os.path.join("vendor",c,".cargo-checksum.json")]if os.path.exists(t)and os.path.exists(cp)for raw in[open(t,"rb").read()]for p in[raw.replace(b"edition = \"2024\"",b"edition = \"2021\"")]if p!=raw for cs in[json.load(open(cp))]]'
	cargo build --release --workspace \
	    --offline \
	    --ignore-rust-version \
	    --exclude asusd-user \
	    --exclude rog-control-center \
	    --exclude rog_simulators

override_dh_auto_test:
	# Upstream cargo tests reach hardware; skip in the pbuilder chroot.

override_dh_auto_install:
	# Handled via debian/asusctl.install (enumerated).
